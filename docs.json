              "guides/rust-native-extension",
              "guides/ipc-python",
              "guides/ipc-nodejs"
            ]
          }
        ]
      },
      {
        "tab": "Referencia",
        "groups": [
          {
            "group": "Referencia",
            "pages": [
              "reference/stdlib",
              "reference/grammar",
              "reference/compiler-errors",
              "reference/manifest-schema"
