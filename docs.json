            "pages": [
              "modules/imports",
              "modules/stdlib-overview",
              "modules/cmd",
              "modules/math",
              "modules/fs",
              "modules/net",
              "modules/web",
              "modules/db",
              "modules/ai"
            ]
          },
          {
            "group": "Rust Interop",
            "pages": [
              "rust-interop/overview",
              "rust-interop/use-rust",
              "rust-interop/exposing-symbols",
